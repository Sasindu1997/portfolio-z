# Database - Use PostgreSQL connection string from Supabase
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://YOUR_SUPABASE_USER:YOUR_PASSWORD@YOUR_HOST.supabase.co:5432/postgres"

# NextAuth Secret - Keep this secret, use the generated value in .env.local
NEXTAUTH_SECRET=""

# NextAuth URL - Set to your production domain
NEXTAUTH_URL="https://your-project.vercel.app"
