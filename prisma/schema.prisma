// Prisma schema for Zenode Portfolio

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  shortDesc   String
  fullDesc    String
  technologies String  // JSON array stored as string
  category    String
  client      String?
  projectUrl  String?
  githubUrl   String?
  featured    Boolean  @default(false)
  published   Boolean  @default(false)
  orderIndex  Int      @default(0)
  thumbnail   String?
  images      String   @default("[]") // JSON array of image URLs
  completedAt DateTime?
  // SEO fields
  seoTitle    String?
  seoDesc     String?
  // Analytics placeholder
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([featured])
  @@index([published])
  @@index([orderIndex])
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  company   String
  content   String
  avatar    String?
  rating    Int      @default(5)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hash
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}
